{
  "expo": {
    "name": "CineID",
    "slug": "movie-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "movie-finder",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C0F"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0C0C0F",
      "package": "com.cineid.moviefinder"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0C0C0F"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
